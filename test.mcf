fn add(x: int, y: int) -> int
    return x + y
end

fn fibb(n: int) -> void
    let i = 0
    let a = 0
    let b = 1

    while i < n:
        mcf 'tellraw @a "$(b)"'
        let next = a + b
        a = b
        b = next
        i = i + 1
    end

    return
end

fn classify(value: int) -> string
    if value == 0:
        return "zero"
    else if value == 1:
        return "one"
    else:
        return "many"
    end
end

fn range_demo(limit: int) -> void
    debug("range demo: start")
    for i in 0..=limit:
        if i == 1 or not false:
            mcf "say range i: $(i)"
        end
    end

    debug("range demo: end")
    return
end

fn loop_control_demo(limit: int) -> void
    debug("loop-control demo: start")
    for i in 0..limit:
        if i == 1:
            debug("loop-control demo: continue at i=1")
            continue
        else if i == 4:
            debug("loop-control demo: break at i=4")
            break
        else:
            mcf "say loop i: $(i)"
        end
    end

    debug("loop-control demo: end")
    return
end

fn name_closest_pig() -> void
    debug("name closest pig: start")
    let player = single(selector("@p"))
    if exists(player):
        player.debug_entity("name demo player")
        let pig = single(at(player, selector("@e[type=pig,sort=nearest]")))
        if exists(pig):
            pig.debug_entity("nearest pig before naming")
            pig.CustomName = "MCFC"
            pig.debug_entity("nearest pig after naming")
        end
    end

    debug("name closest pig: end")
    return
end

fn style_closest_pig() -> void
    debug("style closest pig: start")
    let player = single(selector("@p"))
    if exists(player):
        player.debug_entity("style demo player")
        let pig = single(at(player, selector("@e[type=pig,sort=nearest]")))
        if exists(pig):
            pig.debug_entity("nearest pig before styling")
            pig.CustomName = "MCFC Jr"
            pig.Variant = "minecraft:cold"
            pig.Age = 0 - 24000
            pig.debug_entity("nearest pig after styling")
        end
    end

    debug("style closest pig: end")
    return
end

fn execution_context_demo() -> void
    debug("execution-context demo: start")

    let players = selector("@a[limit=1]")
    # still uses raw mcf/mc for context behavior, but object-style debug helpers now
    as(players):
        mcf 'tellraw @s "as-block: welcome @s"'
        mc "say this raw command is executing as @s"
        mc 'title @s actionbar "actionbar: hello @s"'
    end

    at(players):
        mc "particle minecraft:happy_villager ~ ~1 ~ 0.25 0.25 0.25 0 8"
        block("~ ~1 ~").debug_marker("at-block position marker")
        mcf 'tellraw @a "at-block: sparkles at the player"'
    end

    at(players):
        as(selector("@e[type=pig,sort=nearest,limit=1]")):
            mc "say nested context: nearest pig speaks at the player"
            single(selector("@s")).debug_entity("nested as-at pig")
        end
    end

    let player = single(players)
    if exists(player):
        player.debug_entity("single context demo player")
        let self_ref = single(as(player, selector("@s")))
        if exists(self_ref):
            self_ref.tags.mcfc_as_demo = true
            mcf 'tellraw @a "value-as: tagged the executing player via @s"'
            self_ref.debug_entity("value-as self ref")
        end
    end

    debug("execution-context demo: end")
    return
end

fn player_api_demo() -> void
    debug("player api demo: start")
    let player = single(selector("@p"))
    if exists(player):
        player.debug_entity("player api target")
        at(player):
            block("~ ~1 ~").debug_marker("player api marker above player")
        end
        let air = int(player.nbt.Air)
        player.state.quest_stage = 3
        let stage = int(player.state.quest_stage)
        player.tags.mcfc_demo = true
        let tagged = bool(player.tags.mcfc_demo)
        player.team = "red"
        player.mainhand.item = "minecraft:carrot_on_a_stick"
        player.mainhand.name = "MCFC Blade"
        player.mainhand.count = 1
        player.effect("speed", 10, 1)
        mcf "tellraw @a \"player demo air=$(air) stage=$(stage) tagged=$(tagged)\""
    end

    debug("player api demo: end")
    return
end

fn gameplay_builtin_demo() -> void
    debug("gameplay builtins: start")

    let pig = summon("minecraft:pig")
    pig.debug_entity("summoned gameplay pig")
    pig.add_tag("mcfc_gameplay_demo")
    let tagged = pig.has_tag("mcfc_gameplay_demo")
    pig.team = "blue"
    pig.mainhand.item = "minecraft:carrot_on_a_stick"
    pig.mainhand.name = "Demo Driver"
    pig.mainhand.count = 1
    pig.offhand.item = "minecraft:shield"
    pig.head.item = "minecraft:golden_helmet"
    pig.effect("speed", 15, 1)
    pig.teleport(block("~ ~ ~"))
    pig.damage(2)
    pig.heal(1)
    pig.give("minecraft:apple", 2)
    pig.clear("minecraft:apple", 1)
    pig.loot_give("minecraft:chests/simple_dungeon")
    pig.position.particle("minecraft:happy_villager", 12)

    async:
        sleep(2)
        at(pig):
            block("~ ~-1 ~").setblock("minecraft:gold_block")
        end
        pig.debug_entity("gameplay pig after async marker")
    end

    pig.remove_tag("mcfc_gameplay_demo")

    mcf 'tellraw @a "gameplay builtins tagged-before-remove=$(tagged)"'
    debug("gameplay builtins: end")
    return
end

fn ui_world_builtin_demo() -> void
    debug("ui/world builtins: start")

    let player = single(selector("@p"))
    if exists(player):
        player.debug_entity("ui/world demo player")
        player.tellraw("tellraw method says hello to @p")
        player.title("MCFC Demo $(random(100))")
        player.actionbar("Watch the particles")

        let bb = bossbar("mcfc:demo", "MCFC Bossbar")
        bb.value = 5
        bb.max = 10
        bb.visible = true
        bb.players = player
        bb.name = "MCFC Bossbar Updated"
        player.playsound("minecraft:entity.experience_orb.pickup", "master")

        at(player):
            let feet = block("~ ~-1 ~")
            let spark = block("~ ~1 ~")
            let corner = block("~1 ~-1 ~1")
            spark.debug_marker("particle beacon above player")
            feet.debug_marker("block marker below player", "minecraft:emerald_block")
            feet.fill(corner, "minecraft:glass")
            spark.particle("minecraft:happy_villager")
            spark.particle("minecraft:flame", 30)
            spark.particle("minecraft:end_rod", 30, player)
            feet.loot_insert("minecraft:chests/simple_dungeon")
            spark.loot_spawn("minecraft:chests/simple_dungeon")
        end

        async:
            sleep(2)
            player.stopsound("master", "minecraft:entity.experience_orb.pickup")
            player.tellraw("placing gold block now...")
            sleep(1)
            player.position.particle("minecraft:happy_villager", 20, player)
            at(player):
                block("~ ~-1 ~").setblock("minecraft:gold_block")
            end
            bb.value = 10
            bb.name = "MCFC Bossbar Complete"
            sleep(3)
            at(player):
                player.teleport(single(selector("@e[type=pig,sort=nearest]")))
            end
            bb.remove()
        end
    end

    debug("ui/world builtins: end")
    return
end

fn collection_pick(values: array<int>, index: int) -> int
    return values[index]
end

fn collection_total(counts: dict<int>, key: string) -> int
    return counts[key]
end

fn collections_demo() -> void
    debug("collections demo: start")

    let values = [1, 2, 3]
    let index = 1
    mcf "tellraw @a \"array init index=$(index)\""

    let first = values[0]
    let dynamic = values[index]
    mcf "tellraw @a \"array read values[0]=$(first) values[index]=$(dynamic)\""

    values[index] = first + dynamic
    let after_set = values[index]
    mcf "tellraw @a \"array write values[index]=$(after_set)\""

    values.push(8)
    let pushed = values[3]
    mcf "tellraw @a \"array push values[3]=$(pushed)\""

    let popped = values.pop()
    mcf "tellraw @a \"array pop popped=$(popped)\""

    let length = values.len()
    mcf "tellraw @a \"array len length=$(length)\""

    let picked = collection_pick(values, index)
    mcf "tellraw @a \"array helper pick(values, index)=$(picked)\""

    let labels = ["zero", "one", "two"]
    let label = labels[index]
    mcf "tellraw @a \"string array labels[index]=$(label)\""

    let counts = {"wood": 12, "stone": 4}
    let key = "wood"
    let has_wood = counts.has(key)
    let original_wood = counts[key]
    mcf "tellraw @a \"dict init key=$(key) wood=$(original_wood) has=$(has_wood)\""

    counts[key] = popped + length + picked
    let updated_wood = counts[key]
    mcf "tellraw @a \"dict write counts[key]=$(updated_wood)\""

    counts.remove("stone")
    let has_stone = counts.has("stone")
    mcf "tellraw @a \"dict remove stone has_stone=$(has_stone)\""

    let wood = collection_total(counts, key)
    mcf "tellraw @a \"dict helper total(counts, key)=$(wood)\""

    let nested = [{"score": 1}, {"score": 2}]
    let nested_index = 1
    let nested_key = "score"
    let nested_before = nested[nested_index][nested_key]
    mcf "tellraw @a \"nested before nested[1][score]=$(nested_before)\""

    nested[nested_index][nested_key] = wood
    let nested_score = nested[nested_index][nested_key]
    mcf "tellraw @a \"nested write nested[1][score]=$(nested_score)\""

    if has_wood:
        debug("collections demo: has wood branch reached")
        mcf "tellraw @a \"collections label=$(label) wood=$(wood) nested=$(nested_score)\""
    end

    debug("collections demo: end")
    return
end

fn exp(n: int, k: int) -> int
    let temp = n
    for _ in 0..k-1:
        n = n * temp
    end
    return n
end

fn main() -> void
    let version = 1
    mcf 'tellraw @a "MCFC version 0.0.$(version)"'
    mcf 'tellraw @a "Expression test: $(1 + 2)"'
    
    let a = 2
    let b = 2
    mcf 'tellraw @a "Expression test: $(a + b)"'

    let player = single(selector("@a"))
    as(player):
        mcf 'tellraw @s "*@s* Expression test: $(exp(2, 5))"'
    end

    # let kind = classify(2)
