fn add(x: int, y: int) -> int
    return x + y
end

fn fibb(n: int) -> void
    let i = 0
    let a = 0
    let b = 1

    while i < n:
        mcf 'tellraw @a "$(b)"'
        let next = a + b
        a = b
        b = next
        i = i + 1
    end

    return
end

fn classify(value: int) -> string
    if value == 0:
        return "zero"
    else if value == 1:
        return "one"
    else:
        return "many"
    end
end

fn range_demo(limit: int) -> void
    for i in 0..=limit:
        if i == 1 or not false:
            mcf "say range i: $(i)"
        end
    end

    return
end

fn loop_control_demo(limit: int) -> void
    for i in 0..limit:
        if i == 1:
            continue
        else if i == 4:
            break
        else:
            mcf "say loop i: $(i)"
        end
    end

    return
end

fn name_closest_pig() -> void
    let player = single(selector("@p"))
    if exists(player):
        let pig = single(at(player, selector("@e[type=pig,sort=nearest]")))
        if exists(pig):
            pig.CustomName = "MCFC"
        end
    end

    return
end

fn style_closest_pig() -> void
    let player = single(selector("@p"))
    if exists(player):
        let pig = single(at(player, selector("@e[type=pig,sort=nearest]")))
        if exists(pig):
            pig.CustomName = "MCFC Jr"
            pig.Variant = "minecraft:cold"
            pig.Age = 0 - 24000
        end
    end

    return
end

fn main() -> void
    let version = 1
    mcf 'tellraw @a "MCFC version 0.$(version)"'
    let a = 1
    let b = 2
    let label = "done"

    while a < 4:
        mcf "say a: $(a)"
        if a == 2:
            b = add(a, b)
        end
        a = a + 1
    end

    let kind = classify(2)
    if kind == "many" and not false:
        mcf "say class: $(kind)"
    else:
        mc "say unexpected class"
    end

    range_demo(3)
    loop_control_demo(6)
    fibb(8)
    name_closest_pig()
    style_closest_pig()
    mc "say done"
    return
end
