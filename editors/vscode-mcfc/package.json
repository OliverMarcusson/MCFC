{
  "name": "mcfc-syntax",
  "displayName": "MCFC Language Support",
  "description": "Syntax highlighting, editor basics, and language server support for MCFC .mcf files.",
  "version": "0.0.1",
  "publisher": "mcfc",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git@github.com:OliverMarcusson/MCFC.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:mcfc"
  ],
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "compile": "tsc -p ./",
    "copy-server": "node ./scripts/copy-server.js",
    "vscode:prepublish": "npm run compile && npm run copy-server",
    "prepackage": "npm run compile && npm run copy-server",
    "package": "vsce package"
  },
  "contributes": {
    "languages": [
      {
        "id": "mcfc",
        "aliases": [
          "MCFC",
          "mcfc"
        ],
        "extensions": [
          ".mcf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mcfc",
        "scopeName": "source.mcfc",
        "path": "./syntaxes/mcfc.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.15.0",
    "typescript": "^5.4.5"
  }
}
