# MCFC syntax highlighting fixture

@book
fn launch(level: int) -> void
    mcf "tellraw @a \"launching level $(level)\""
    return
end

fn classify(value: int) -> string
    if value == 0:
        return 'zero'
    else if value < 10 and not false:
        return "small"
    else:
        return "large"
    end
end

fn main() -> void
    let player = single(selector("@p"))
    let pig = single(selector("@e[type=pig,limit=1]"))
    let chest = block("0 64 0")
    let values = [1, 2, 3]
    let counts = {"wood": 12, "stone": 4}

    for i in 0..=10:
        values.push(i)
        if i == 5:
            continue
        end
    end

    for pig in selector("@e[type=pig]"):
        pig.CustomName = "Highlighted"
    end

    player.tags.mcfc_demo = true
    player.effect("speed", 10, 1)
    pig.add_tag("elite")
    pig.offhand.item = "minecraft:shield"
    summon("minecraft:pig")
    teleport(pig, block("~ ~1 ~"))
    damage(pig, 2)
    heal(pig, 1)
    give(pig, "minecraft:apple", 1)
    clear(pig, "minecraft:apple", 1)
    loot_give(pig, "minecraft:chests/simple_dungeon")
    loot_insert(chest, "minecraft:chests/simple_dungeon")
    tellraw(pig, "hello @s")
    title(pig, "Warning")
    actionbar(pig, "Incoming")
    debug("entered gameplay branch")
    debug_marker(chest, "chest marker", "minecraft:gold_block")
    debug_entity(pig, "nearest pig")
    bossbar_add("mcfc:test", "Boss")
    bossbar_players("mcfc:test", pig)
    playsound("minecraft:entity.experience_orb.pickup", "master", pig)
    stopsound(pig, "master", "minecraft:entity.experience_orb.pickup")
    particle("minecraft:flame", chest, 4, pig)
    setblock(chest, "minecraft:stone")
    fill(chest, block("1 65 1"), "minecraft:glass")
    chest.Items[0].Count = values.len()
    counts.remove("stone")

    let amount = values.len()
    mc "say plain command"
    mcf "say count $(amount)"
end
