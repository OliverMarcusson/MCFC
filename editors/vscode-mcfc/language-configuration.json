{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["<", ">"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["<", ">"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:fn\\b.*|struct\\b.*:|(?:if|else(?:\\s+if)?|while|for|as|at|match)\\b.*:|async\\s*:)\\s*(?:#.*)?$",
    "decreaseIndentPattern": "^\\s*(?:end\\b|else\\s*:)\\s*(?:#.*)?$"
  }
}
